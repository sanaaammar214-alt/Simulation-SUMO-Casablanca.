<configuration>
    <input>
        <net-file value="casablanca.net.xml"/>
        <route-files value="routes.rou.xml"/>
    </input>

    <time>
        <begin value="0"/>
        <end value="10800"/>
    </time>

    <processing>
        <max-num-vehicles value="50"/>
        <ignore-route-errors value="true"/>
    </processing>

    <report>
        <no-warnings value="true"/>
        <no-step-log value="true"/>
    </report>
</configuration>